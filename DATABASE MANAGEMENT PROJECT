-- Stored procedure to retrieve a full profile for a named historical figure,
-- including their fields of study and organizations they worked for.
DELIMITER //

CREATE PROCEDURE GetPersonProfile(IN p_full_name VARCHAR(200))
BEGIN
    -- Return basic person info
    SELECT p.person_id, p.full_name, p.birth_year, p.death_year,
           c.country_name,
           CASE WHEN p.death_year IS NULL THEN 'Alive'
                ELSE CAST(p.death_year - p.birth_year AS CHAR)
           END AS age_at_death,
           p.biography
    FROM Person p
    JOIN Country c ON p.country_id = c.country_id
    WHERE p.full_name LIKE CONCAT('%', p_full_name, '%');

    -- Return their fields of study
    SELECT f.field_name
    FROM Person p
    JOIN PersonField pf ON p.person_id = pf.person_id
    JOIN Field f ON pf.field_id = f.field_id
    WHERE p.full_name LIKE CONCAT('%', p_full_name, '%');

    -- Return organizations they worked for
    SELECT o.org_name
    FROM Person p
    JOIN PersonOrganization po ON p.person_id = po.person_id
    JOIN Organization o ON po.org_id = o.org_id
    WHERE p.full_name LIKE CONCAT('%', p_full_name, '%');
END //

DELIMITER ;


