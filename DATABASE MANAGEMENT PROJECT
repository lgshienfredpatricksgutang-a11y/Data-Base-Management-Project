-- =============================================================
-- DATABASE MANAGEMENT - ASSESSMENT 2
-- Historical STEM Figures Database
-- Normalized to Third Normal Form (3NF)
-- =============================================================

-- Drop database if it exists and recreate cleanly
DROP DATABASE IF EXISTS historical_stem;
CREATE DATABASE historical_stem CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE historical_stem;

-- =============================================================
-- SECTION 1: HISTORICAL FIGURES TABLES (3NF Design)
-- =============================================================

-- Country table: Eliminates repeating country names in Person table,
-- removing the transitive dependency Person → country_name
CREATE TABLE Country (
    country_id   INT          AUTO_INCREMENT PRIMARY KEY,
    country_name VARCHAR(100) NOT NULL UNIQUE
);

-- Field table: Eliminates repeating field names and removes
-- the multi-valued dependency on the Person table
CREATE TABLE Field (
    field_id   INT          AUTO_INCREMENT PRIMARY KEY,
    field_name VARCHAR(100) NOT NULL UNIQUE
);

-- Person table: Core table for historical STEM figures.
-- death_year is NULL for figures still alive.
-- All non-key attributes depend solely on person_id (3NF compliant).
CREATE TABLE Person (
    person_id   INT          AUTO_INCREMENT PRIMARY KEY,
    full_name   VARCHAR(200) NOT NULL,
    first_name  VARCHAR(100),
    last_name   VARCHAR(100),
    birth_year  INT,
    death_year  INT          NULL,        -- NULL = still alive
    country_id  INT          NOT NULL,
    biography   TEXT,
    CONSTRAINT fk_person_country FOREIGN KEY (country_id) REFERENCES Country(country_id)
);

-- PersonField junction table: Resolves the many-to-many relationship
-- between Person and Field (a person can contribute to many fields,
-- and a field can have many contributors)
CREATE TABLE PersonField (
    person_id INT NOT NULL,
    field_id  INT NOT NULL,
    PRIMARY KEY (person_id, field_id),
    CONSTRAINT fk_pf_person FOREIGN KEY (person_id) REFERENCES Person(person_id),
    CONSTRAINT fk_pf_field  FOREIGN KEY (field_id)  REFERENCES Field(field_id)
);

-- Organization table: Stores employers/institutions
-- (e.g. NASA, DuPont, Royal Society)
CREATE TABLE Organization (
    org_id   INT          AUTO_INCREMENT PRIMARY KEY,
    org_name VARCHAR(200) NOT NULL UNIQUE
);

-- PersonOrganization junction table: Many-to-many between Person and Organization
CREATE TABLE PersonOrganization (
    person_id INT NOT NULL,
    org_id    INT NOT NULL,
    PRIMARY KEY (person_id, org_id),
    CONSTRAINT fk_po_person FOREIGN KEY (person_id) REFERENCES Person(person_id),
    CONSTRAINT fk_po_org    FOREIGN KEY (org_id)    REFERENCES Organization(org_id)
);

-- Collaboration table: Records notable named collaborators for each person
-- (used to answer queries like "who worked with Einstein?")
CREATE TABLE Collaboration (
    collaboration_id   INT          AUTO_INCREMENT PRIMARY KEY,
    person_id          INT          NOT NULL,
    collaborator_name  VARCHAR(200) NOT NULL,
    collaboration_note VARCHAR(500),
    CONSTRAINT fk_collab_person FOREIGN KEY (person_id) REFERENCES Person(person_id)
);

