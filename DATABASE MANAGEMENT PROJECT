-- Query 1: List all historical figures born in France
SELECT p.full_name, p.birth_year, p.death_year, c.country_name
FROM Person p
JOIN Country c ON p.country_id = c.country_id
WHERE c.country_name = 'France'
ORDER BY p.birth_year;

-- Query 2: List all historical figures who contributed to Computing
SELECT p.full_name, p.birth_year, p.death_year, c.country_name
FROM Person p
JOIN PersonField pf ON p.person_id = pf.person_id
JOIN Field f ON pf.field_id = f.field_id
JOIN Country c ON p.country_id = c.country_id
WHERE f.field_name = 'Computing'
ORDER BY p.birth_year;

-- Query 3: List all historical figures who contributed to more than 1 field
SELECT p.full_name,
       COUNT(pf.field_id) AS number_of_fields,
       GROUP_CONCAT(f.field_name ORDER BY f.field_name SEPARATOR ', ') AS fields
FROM Person p
JOIN PersonField pf ON p.person_id = pf.person_id
JOIN Field f ON pf.field_id = f.field_id
GROUP BY p.person_id, p.full_name
HAVING COUNT(pf.field_id) > 1
ORDER BY number_of_fields DESC, p.full_name;

-- Query 4: Update Mary Jackson's death year to 2005
-- (The data incorrectly listed her death as 1944; she actually died in 2005)
UPDATE Person
SET death_year = 2005
WHERE full_name = 'Mary Jackson';

-- Verify the update
SELECT full_name, birth_year, death_year
FROM Person
WHERE full_name = 'Mary Jackson';

-- Query 5: List all historical figures who died before they were 40
SELECT p.full_name,
       p.birth_year,
       p.death_year,
       (p.death_year - p.birth_year) AS age_at_death,
       c.country_name
FROM Person p
JOIN Country c ON p.country_id = c.country_id
WHERE p.death_year IS NOT NULL
  AND (p.death_year - p.birth_year) < 40
ORDER BY age_at_death;

-- Query 6: Which countries have the most historical figures listed?
SELECT c.country_name,
       COUNT(p.person_id) AS number_of_figures
FROM Country c
JOIN Person p ON c.country_id = p.country_id
GROUP BY c.country_id, c.country_name
ORDER BY number_of_figures DESC;

-- Query 7: Are any historical figures still alive? If so, who?
SELECT p.full_name,
       p.birth_year,
       (2026 - p.birth_year) AS approximate_age,
       c.country_name
FROM Person p
JOIN Country c ON p.country_id = c.country_id
WHERE p.death_year IS NULL;

-- Query 8: Which historical figures worked for NASA?
SELECT p.full_name, p.birth_year, p.death_year, c.country_name, o.org_name
FROM Person p
JOIN PersonOrganization po ON p.person_id = po.person_id
JOIN Organization o ON po.org_id = o.org_id
JOIN Country c ON p.country_id = c.country_id
WHERE o.org_name = 'NASA'
ORDER BY p.full_name;

-- Query 9: Which historical figures worked with Einstein?
SELECT DISTINCT p.full_name,
       p.birth_year,
       p.death_year,
       c.country_name,
       col.collaboration_note
FROM Person p
JOIN Collaboration col ON p.person_id = col.person_id
JOIN Country c ON p.country_id = c.country_id
WHERE col.collaborator_name LIKE '%Einstein%'
ORDER BY p.full_name;

-- Query 10: Which countries have the most fields of research contributions?
-- Counts distinct field contributions per country (avoids duplicate field counting)
SELECT c.country_name,
       COUNT(DISTINCT pf.field_id) AS distinct_fields,
       GROUP_CONCAT(DISTINCT f.field_name ORDER BY f.field_name SEPARATOR ', ') AS fields_contributed
FROM Country c
JOIN Person p ON c.country_id = p.country_id
JOIN PersonField pf ON p.person_id = pf.person_id
JOIN Field f ON pf.field_id = f.field_id
GROUP BY c.country_id, c.country_name


ORDER BY distinct_fields DESC;
