// ── Query 5: Figures who died before age 40 ───────────────────
print("\n── Query 5: Figures who died before age 40 ──");
db.people.find(
  {
    $expr: {
      $and: [
        { $ne: ["$death_year", null] },
        { $lt: [{ $subtract: ["$death_year", "$birth_year"] }, 40] }
      ]
    }
  },
  {
    full_name: 1, birth_year: 1, death_year: 1,
    age_at_death: { $subtract: ["$death_year", "$birth_year"] },
    _id: 0
  }
).sort({ birth_year: 1 }).forEach(printjson);

// ── Query 6: Countries with the most figures ──────────────────
print("\n── Query 6: Countries with most historical figures ──");
db.people.aggregate([
  { $group: { _id: "$country", number_of_figures: { $sum: 1 } } },
  { $sort: { number_of_figures: -1 } },
  { $project: { country_name: "$_id", number_of_figures: 1, _id: 0 } }
]).forEach(printjson);

