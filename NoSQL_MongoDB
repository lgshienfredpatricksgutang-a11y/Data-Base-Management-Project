).sort({ full_name: 1 }).forEach(printjson);

// ── Query 10: Countries with most distinct fields ─────────────
print("\n── Query 10: Countries with most distinct fields of research ──");
db.people.aggregate([
  { $unwind: "$fields" },
  { $group: { _id: "$country", fields: { $addToSet: "$fields" } } },
  { $project: {
      country_name: "$_id",
      distinct_fields: { $size: "$fields" },
      fields_contributed: "$fields",
      _id: 0
  }},
  { $sort: { distinct_fields: -1 } }
]).forEach(printjson);

print("\n✓ All 10 queries complete.");
